<%- include('../partials/head', { title: 'Dashboard' }) %>
<body class="min-h-screen bg-slate-50 text-slate-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap');

    .dash-shell {
      font-family: 'Outfit', sans-serif;
      min-height: calc(100vh - 3.5rem);
      background:
        radial-gradient(circle at 15% 50%, rgba(99, 102, 241, 0.08), transparent 50%),
        radial-gradient(circle at 85% 30%, rgba(56, 189, 248, 0.08), transparent 50%),
        linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
    }

    .dash-main {
      min-height: calc(100vh - 3.5rem);
      display: flex;
      flex-direction: column;
    }

    .dash-content {
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .dash-title {
      font-family: 'Sora', sans-serif;
      letter-spacing: -0.03em;
    }

    .dash-hero {
      border-radius: 1.6rem;
      background: linear-gradient(132deg, #0f172a 0%, #1e293b 57%, #334155 100%);
      box-shadow: 0 22px 55px rgba(15, 23, 42, 0.24);
      position: relative;
      overflow: hidden;
    }

    .dash-hero::before {
      content: '';
      position: absolute;
      width: 320px;
      height: 320px;
      border-radius: 999px;
      right: -95px;
      top: -170px;
      background: rgba(251, 191, 36, 0.32);
    }

    .dash-hero::after {
      content: '';
      position: absolute;
      width: 260px;
      height: 260px;
      border-radius: 999px;
      left: -90px;
      bottom: -140px;
      background: rgba(34, 211, 238, 0.2);
    }

    .dash-card {
      border: 1px solid #e8eef6;
      background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
      border-radius: 1.2rem;
    }

    .dash-action {
      border: 1px solid #ecf0f7;
      background: #fff;
      border-radius: 1rem;
      transition: transform 0.22s ease, box-shadow 0.24s ease, border-color 0.22s ease;
    }

    .dash-action:hover {
      transform: translateY(-3px);
      box-shadow: 0 18px 32px rgba(14, 23, 38, 0.1);
      border-color: #cfd9e6;
    }

    @media (max-width: 768px) {
      .dash-hero {
        border-radius: 1.15rem;
      }
    }
    .schedule-tab.active {
      border-color: #f97316;
      color: #ea580c;
    }
    .pulse-live {
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
      animation: pulse 1.6s infinite;
    }
    @keyframes pulse {
      0% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7);
      }
      70% {
        transform: scale(1);
        box-shadow: 0 0 0 6px rgba(239, 68, 68, 0);
      }
      100% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(239, 68, 68, 0);
      }
    }
  
    .hide-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .hide-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <div class="md:ml-60 pt-14 page-body dash-shell dash-main">
    <div class="max-w-7xl w-full mx-auto px-4 md:px-8 py-6 md:py-8 dash-content">      <!-- Cohort Selector -->
      <section class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 md:p-6 mt-6 fade-up-1">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          <div>
            <h2 class="dash-title text-lg font-bold text-slate-800 flex items-center gap-2">
              <span class="text-xl">🎓</span> Selected Cohort
            </h2>
            <p class="text-xs text-slate-500 mt-0.5">Toggle between your purchased courses to view live schedules and subject-wise lectures.</p>
          </div>
          <div>
            <label for="cohort-selector" class="sr-only">Choose Course Cohort</label>
            <select id="cohort-selector" class="w-full sm:w-auto px-4 py-2.5 border border-slate-200 rounded-xl text-xs font-bold text-slate-700 bg-white shadow-sm focus:outline-none focus:border-slate-300">
              <option value="">Loading your cohorts...</option>
            </select>
          </div>
        </div>
      </section>

      <!-- Interactive Subject-Wise Schedule -->
      <div class="mt-6 fade-up-1">
        <div id="cohort-empty-state" class="hidden py-12 text-center bg-white rounded-2xl shadow-sm border border-slate-100 p-5 md:p-6">
          <div class="text-4xl mb-3">📚</div>
          <p class="text-sm font-semibold text-slate-600">No active cohorts found</p>
          <p class="text-xs text-slate-400 mt-1 max-w-sm mx-auto">You have not purchased any courses yet. Unlock a course to view scheduled lectures and interactive feeds.</p>
          <a href="/student/purchase-courses" class="inline-block mt-4 px-4 py-2 bg-slate-800 text-white rounded-xl text-xs font-bold hover:bg-slate-900 transition">Browse Courses</a>
        </div>

        
        <div id="cohort-schedule-content" class="hidden flex flex-col gap-6">
          <!-- Ongoing / Live -->
          <div id="section-ongoing" class="hidden space-y-4 bg-white rounded-2xl shadow-sm border border-slate-100 p-5 md:p-6">
            <h3 class="font-bold text-slate-800 text-base md:text-lg flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-red-500 pulse-live"></span> Live / Ongoing
            </h3>
            <div id="container-ongoing" class="flex overflow-x-auto pb-4 gap-4 snap-x scrollbar-hide hide-scrollbar"></div>
          </div>

          <!-- Upcoming -->
          <div id="section-upcoming" class="hidden space-y-4 bg-white rounded-2xl shadow-sm border border-slate-100 p-5 md:p-6">
            <h3 class="font-bold text-slate-800 text-base md:text-lg flex items-center gap-2">
              <span class="text-xl">📅</span> Upcoming
            </h3>
            <div id="container-upcoming" class="flex overflow-x-auto pb-4 gap-4 snap-x scrollbar-hide hide-scrollbar"></div>
          </div>

          <!-- Completed -->
          <div id="section-completed" class="hidden space-y-4 bg-white rounded-2xl shadow-sm border border-slate-100 p-5 md:p-6">
            <h3 class="font-bold text-slate-800 text-base md:text-lg flex items-center gap-2">
              <span class="text-xl">✅</span> Completed
            </h3>
            <div id="container-completed" class="flex overflow-x-auto pb-4 gap-4 snap-x scrollbar-hide hide-scrollbar"></div>
          </div>

          <!-- Cancelled -->
          <div id="section-cancelled" class="hidden space-y-4 bg-white rounded-2xl shadow-sm border border-slate-100 p-5 md:p-6">
            <h3 class="font-bold text-slate-800 text-base md:text-lg flex items-center gap-2">
              <span class="text-xl">❌</span> Cancelled
            </h3>
            <div id="container-cancelled" class="flex overflow-x-auto pb-4 gap-4 snap-x scrollbar-hide hide-scrollbar"></div>
          </div>
        </div>
      </div>

      <section class="grid grid-cols-2 lg:grid-cols-4 gap-4 mt-6 fade-up-1">
        <a href="/student/study" class="dash-action p-4 md:p-5 flex flex-col gap-2.5">
          <div class="w-11 h-11 rounded-xl bg-blue-50 flex items-center justify-center text-blue-700 text-xl">&#128218;</div>
          <p class="text-base font-semibold text-slate-800">Study Hub</p>
          <p class="text-sm text-slate-500">Access your lectures and revision flow.</p>
        </a>
        <a href="/student/purchase-series" class="dash-action p-4 md:p-5 flex flex-col gap-2.5">
          <div class="w-11 h-11 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-700 text-xl">&#128722;</div>
          <p class="text-base font-semibold text-slate-800">Buy Series</p>
          <p class="text-sm text-slate-500">Unlock new tests and challenges.</p>
        </a>
        <a href="/student/tests" class="dash-action p-4 md:p-5 flex flex-col gap-2.5">
          <div class="w-11 h-11 rounded-xl bg-violet-50 flex items-center justify-center text-violet-700 text-xl">&#128221;</div>
          <p class="text-base font-semibold text-slate-800">My Tests</p>
          <p class="text-sm text-slate-500">Attempt and review your test history.</p>
        </a>
        <a href="/student/purchases" class="dash-action p-4 md:p-5 flex flex-col gap-2.5">
          <div class="w-11 h-11 rounded-xl bg-amber-50 flex items-center justify-center text-amber-700 text-xl">&#128179;</div>
          <p class="text-base font-semibold text-slate-800">Purchases</p>
          <p class="text-sm text-slate-500">Track all your course and series orders.</p>
        </a>
      </section>
      </div>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', async () => {
      requireAuth('student');
      const user = getUser();
      if (user) {
        const el = document.getElementById('welcome-title');
        if (el) el.textContent = 'Welcome back, ' + user.name.split(' ')[0] + '!';
      }

      // Cohort Schedule System
      const cohortSelector = document.getElementById('cohort-selector');
      const cohortEmptyState = document.getElementById('cohort-empty-state');
      const cohortScheduleContent = document.getElementById('cohort-schedule-content');
      
      const sectionOngoing = document.getElementById('section-ongoing');
      const sectionUpcoming = document.getElementById('section-upcoming');
      const sectionCompleted = document.getElementById('section-completed');
      const sectionCancelled = document.getElementById('section-cancelled');
      
      const containerOngoing = document.getElementById('container-ongoing');
      const containerUpcoming = document.getElementById('container-upcoming');
      const containerCompleted = document.getElementById('container-completed');
      const containerCancelled = document.getElementById('container-cancelled');

      let activeCourse = null;

      try {
        const purchases = await API.get('/purchase/my?itemType=Course');
        if (!purchases || purchases.length === 0) {
          cohortSelector.innerHTML = '<option value="">No courses purchased</option>';
          cohortEmptyState.classList.remove('hidden');
          cohortScheduleContent.classList.add('hidden');
          return;
        }

        cohortSelector.innerHTML = purchases.map((p, idx) => {
          const course = p.course || p.itemId;
          if (!course) return '';
          return `<option value="${course._id}" ${idx === 0 ? 'selected' : ''}>${escapeHtml(course.name)}</option>`;
        }).join('');

        const firstCourse = purchases[0].course || purchases[0].itemId;
        if (firstCourse) {
          await loadCohortDetails(firstCourse._id);
        }

        cohortSelector.addEventListener('change', async (e) => {
          const courseId = e.target.value;
          if (courseId) {
            await loadCohortDetails(courseId);
          }
        });
      } catch (err) {
        console.error(err);
        cohortSelector.innerHTML = '<option value="">Error loading courses</option>';
      }

      async function loadCohortDetails(courseId) {
        try {
          const course = await API.get(`/courses/published/${courseId}`);
          activeCourse = course;
          renderSchedule();
        } catch (err) {
          console.error('Error loading schedule:', err);
        }
      }

      function renderSchedule() {
        if (!activeCourse) return;

        cohortEmptyState.classList.add('hidden');
        cohortScheduleContent.classList.remove('hidden');

        const ongoingList = [];
        const upcomingList = [];
        const completedList = [];
        const cancelledList = [];

        if (Array.isArray(activeCourse.subjects)) {
          activeCourse.subjects.forEach(subject => {
            if (!subject || !Array.isArray(subject.chapters)) return;
            subject.chapters.forEach(chapter => {
              if (!chapter || !Array.isArray(chapter.lectures)) return;
              chapter.lectures.forEach(lecture => {
                const lecData = {
                  ...lecture,
                  subjectName: subject.name,
                  chapterName: chapter.name
                };
                if (lecture.status === 'live') {
                  ongoingList.push(lecData);
                } else if (lecture.status === 'scheduled') {
                  upcomingList.push(lecData);
                } else if (lecture.status === 'cancelled') {
                  cancelledList.push(lecData);
                } else {
                  if (lecture.scheduledAt) {
                    const today = new Date();
                    const lecDate = new Date(lecture.scheduledAt);
                    if (lecDate.getFullYear() === today.getFullYear() &&
                        lecDate.getMonth() === today.getMonth() &&
                        lecDate.getDate() === today.getDate()) {
                      completedList.push(lecData);
                    }
                  }
                }
              });
            });
          });
        }

        renderHorizontalList(ongoingList, sectionOngoing, containerOngoing, 'No ongoing classes.');
        renderHorizontalList(upcomingList, sectionUpcoming, containerUpcoming, 'No upcoming classes.');
        renderHorizontalList(completedList, sectionCompleted, containerCompleted, 'No completed lectures.');
        renderHorizontalList(cancelledList, sectionCancelled, containerCancelled, 'No cancelled classes.');
      }

      function renderHorizontalList(list, sectionEl, containerEl, emptyMsg) {
        sectionEl.classList.remove('hidden');
        if (!list || list.length === 0) {
          containerEl.innerHTML = `
            <div class="w-full text-center py-8 text-slate-400 text-sm italic border border-dashed border-slate-200 rounded-xl">
              ${emptyMsg}
            </div>
          `;
          return;
        }
        
        containerEl.innerHTML = list.map(lecture => {
          let actionHtml = '';
          let badgeHtml = '';
          
          if (lecture.status === 'live') {
            badgeHtml = `<span class="px-2 py-0.5 bg-red-100 text-red-600 rounded-md text-[9px] font-black tracking-widest uppercase mb-2 inline-block">LIVE NOW</span>`;
            actionHtml = `
              <a href="/student/course/${activeCourse._id}/player?lectureId=${lecture._id}" class="mt-3 w-full block text-center px-4 py-2.5 rounded-xl bg-red-500 text-white text-xs font-bold hover:bg-red-600 transition shadow-sm">
                Join Class
              </a>
            `;
          } else if (lecture.status === 'scheduled') {
            const formattedDate = formatScheduledDate(lecture.scheduledAt);
            badgeHtml = `<span class="px-2 py-0.5 bg-blue-100 text-blue-600 rounded-md text-[9px] font-black tracking-widest uppercase mb-2 inline-block">UPCOMING</span>`;
            actionHtml = `
              <div class="mt-3 w-full text-center px-4 py-2.5 bg-blue-50 text-blue-700 text-xs font-bold rounded-xl border border-blue-100">
                📅 ${formattedDate}
              </div>
            `;
          } else if (lecture.status === 'cancelled') {
            badgeHtml = `<span class="px-2 py-0.5 bg-slate-100 text-slate-600 rounded-md text-[9px] font-black tracking-widest uppercase mb-2 inline-block">CANCELLED</span>`;
            actionHtml = `
              <div class="mt-3 w-full text-center px-4 py-2.5 bg-slate-50 text-slate-400 text-xs font-bold rounded-xl border border-slate-100">
                🚫 Class Cancelled
              </div>
            `;
          } else {
            badgeHtml = `<span class="px-2 py-0.5 bg-emerald-100 text-emerald-600 rounded-md text-[9px] font-black tracking-widest uppercase mb-2 inline-block">COMPLETED</span>`;
            actionHtml = `
              <a href="/student/course/${activeCourse._id}/player?lectureId=${lecture._id}" class="mt-3 w-full block text-center px-4 py-2.5 rounded-xl bg-slate-100 text-slate-700 text-xs font-bold hover:bg-slate-200 transition shadow-sm">
                Watch Recording
              </a>
            `;
          }

          return `
            <div class="min-w-[260px] md:min-w-[280px] w-[260px] md:w-[280px] shrink-0 snap-center bg-white border border-slate-200 hover:border-slate-300 rounded-2xl p-5 flex flex-col justify-between shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group relative overflow-hidden">
              <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-slate-200 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <div>
                ${badgeHtml}
                <p class="text-[10px] font-extrabold uppercase tracking-[0.15em] text-slate-500 truncate" title="${escapeHtml(lecture.subjectName)} - ${escapeHtml(lecture.chapterName)}">
                  ${escapeHtml(lecture.subjectName)} • ${escapeHtml(lecture.chapterName)}
                </p>
                <h5 class="text-[15px] font-bold text-slate-900 mt-1.5 line-clamp-2 leading-tight group-hover:text-blue-700 transition-colors">${escapeHtml(lecture.title)}</h5>
              </div>
              <div class="mt-4 pt-4 border-t border-slate-50 border-dashed">
                ${actionHtml}
              </div>
            </div>
          `;
        }).join('');
      }


      function formatScheduledDate(dateString) {
        if (!dateString) return 'TBD';
        const d = new Date(dateString);
        if (isNaN(d.getTime())) return 'TBD';
        return d.toLocaleDateString('en-IN', {
          day: '2-digit',
          month: 'short',
          hour: '2-digit',
          minute: '2-digit',
          hour12: true
        });
      }

      function escapeHtml(str) {
        if (str === null || str === undefined) return '';
        return String(str)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#039;');
      }
    });
  </script>
</body>
</html>
