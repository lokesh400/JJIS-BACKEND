<%- include('../partials/head', { title: 'Live Classes' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen page-body">
    <!-- Header -->
    <div class="page-header px-6 md:px-8 py-7 fade-up">
      <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-1">Student Portal</p>
      <h1 class="text-2xl md:text-3xl font-bold text-white">Live Classes</h1>
      <p class="text-white/60 text-sm mt-1">Attend live sessions, interact via chat, and download study notes</p>
    </div>

    <!-- Main Container -->
    <div class="p-6 md:p-8">
      <!-- Dynamic Classroom Container -->
      <div id="student-classes-container" class="space-y-8 fade-up">
        <!-- Spinner -->
        <div class="text-center py-16 bg-white rounded-3xl border border-gray-100 p-8 shadow-sm">
          <div class="animate-spin inline-block w-8 h-8 border-4 border-current border-t-transparent text-garud-accent rounded-full" role="status"></div>
          <p class="text-gray-400 text-sm mt-3">Loading classroom sessions...</p>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/student/live-classes.js"></script>
</body>
</html>
