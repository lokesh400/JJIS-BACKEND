<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Print Test Paper</title>
  <style>
    :root {
      --ink: #111827;
      --muted: #6b7280;
      --line: #e5e7eb;
      --paper: #ffffff;
      --accent: #0f172a;
      --bg: #f8fafc;
    }

    * {
      box-sizing: border-box;
    }

    .hidden {
      display: none !important;
    }

    html, body {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--ink);
      font-family: Arial, Helvetica, sans-serif;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    @page {
      size: A4;
      margin: 5mm;
    }

    .toolbar {
      max-width: 980px;
      margin: 0 auto;
      padding: 8px 8px 0;
      display: flex;
      justify-content: flex-end;
      align-items: center;
    }

    .print-btn {
      appearance: none;
      border: 0;
      background: var(--accent);
      color: #fff;
      border-radius: 10px;
      padding: 10px 16px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 8px 20px rgba(15, 23, 42, 0.14);
    }

    .print-btn:hover {
      background: #1f2937;
    }

    .loading {
      max-width: 980px;
      margin: 12px auto;
      padding: 12px 16px 0;
      color: var(--muted);
      font-size: 15px;
    }

    .paper {
      max-width: 980px;
      margin: 0 auto;
      padding: 0 8px 0;
      background: var(--paper);
    }

    .header {
      text-align: center;
      padding: 6px 0 18px;
      border-bottom: 1px solid var(--line);
      margin-bottom: 18px;
    }

    .title {
      margin: 0;
      font-size: 26px;
      line-height: 1.2;
      font-weight: 800;
      color: var(--ink);
      letter-spacing: 0.2px;
    }

    .meta {
      margin-top: 8px;
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 10px 18px;
      color: var(--muted);
      font-size: 13px;
    }

    .section {
      margin-top: 18px;
    }

    .section-title {
      margin: 0 0 12px;
      padding-top: 4px;
      font-size: 16px;
      font-weight: 800;
      color: var(--ink);
    }

    .question-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 16px;
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .question-card {
      display: flex;
      align-items: flex-start;
      gap: 0px;
      min-width: 0;
      width: 100%;
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .question-no {
      flex: 0 0 auto;
      min-width: 34px;
      font-weight: 800;
      font-size: 14px;
      line-height: 1.45;
      color: var(--ink);
      padding-top: 1px;
    }

    .question-content {
      flex: 1 1 auto;
      min-width: 0;
    }

    .question-image {
      display: block;
      width: 100%;
      height: auto;
      border: 0;
      outline: 0;
    }

    .image-placeholder {
      width: 100%;
      min-height: 84px;
    }

    .question-foot {
      display: none;
    }

    .error {
      color: #b91c1c;
      font-size: 14px;
      line-height: 1.5;
      margin-top: 10px;
    }

    @media print {
      html, body {
        background: #fff;
      }

      .toolbar {
        display: none !important;
      }

      .loading {
        display: none !important;
      }

      .paper {
        max-width: none;
        margin: 0;
        padding: 0;
      }

      .question-row {
        grid-template-columns: 1fr 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="toolbar no-print">
    <button class="print-btn" type="button" onclick="window.print()">Print Test Paper</button>
  </div>

  <div id="loading" class="loading">Generating test paper...</div>

  <main id="paper" class="paper hidden"></main>

  <script>
    (function () {
      const testData = <%- testData %>  ;
      const paperEl = document.getElementById('paper');
      const loadingEl = document.getElementById('loading');
      const MAX_PAPER_WIDTH = 980;

      const escapeHtml = (value) => String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

      const sections = Array.isArray(testData.sections) ? testData.sections : [];
      const totalQuestions = sections.reduce((sum, section) => {
        return sum + (Array.isArray(section.questions) ? section.questions.length : 0);
      }, 0);

      function renderQuestionCard(questionEntry, questionNumber) {
        const question = (questionEntry && questionEntry.question) ? questionEntry.question : {};
        const imageUrl = question.imageUrl ? escapeHtml(question.imageUrl) : '';

        return `
          <div class="question-card">
            <div class="question-no">Q${questionNumber}</div>
            <div class="question-content">
              ${imageUrl ? `<img class="question-image" src="${imageUrl}" alt="Question ${questionNumber}">` : '<div class="image-placeholder"></div>'}
            </div>
          </div>
        `;
      }

      function buildSectionRows(sectionQuestions, startQuestionNumber) {
        const rows = [];
        for (let i = 0; i < sectionQuestions.length; i += 2) {
          const left = {
            questionEntry: sectionQuestions[i],
            questionNumber: startQuestionNumber + i,
          };
          const right = sectionQuestions[i + 1]
            ? {
                questionEntry: sectionQuestions[i + 1],
                questionNumber: startQuestionNumber + i + 1,
              }
            : null;

          rows.push({
            type: 'pair',
            items: [left, right],
          });
        }
        return rows;
      }

      function render() {
        try {
          let html = '';
          html += `
            <section class="header">
              <h1 class="title">${escapeHtml(testData.name || 'Test Paper')}</h1>
              <div class="meta">
                <span>Duration: ${escapeHtml(testData.duration || '-')} minutes</span>
                <span>Total Questions: ${totalQuestions}</span>
                ${testData.description ? `<span>${escapeHtml(testData.description)}</span>` : ''}
              </div>
            </section>
          `;

          let questionCounter = 1;
          for (let sectionIndex = 0; sectionIndex < sections.length; sectionIndex += 1) {
            const section = sections[sectionIndex];
            const sectionQuestions = Array.isArray(section.questions) ? section.questions : [];
            const rows = buildSectionRows(sectionQuestions, questionCounter);

            html += `<section class="section">`;
            html += `<h2 class="section-title">${escapeHtml(section.name || `Section ${sectionIndex + 1}`)}</h2>`;

            rows.forEach((row) => {
              html += `<div class="question-row">`;
              html += renderQuestionCard(row.items[0].questionEntry, row.items[0].questionNumber);
              if (row.items[1]) {
                html += renderQuestionCard(row.items[1].questionEntry, row.items[1].questionNumber);
              } else {
                html += '<div class="question-card"></div>';
              }
              html += `</div>`;
            });

            questionCounter += sectionQuestions.length;
            html += `</section>`;
          }

          paperEl.innerHTML = html;
          paperEl.classList.remove('hidden');
          loadingEl.remove();
        } catch (error) {
          loadingEl.innerHTML = `<div class="error">Error loading test preview: ${escapeHtml(error.message)}</div>`;
        }
      }

      render();
    })();
  </script>
</body>
</html>
