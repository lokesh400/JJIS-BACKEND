<%- include('../partials/head', { title: 'Batch Details & Enrollment' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen page-body">
    <!-- Header -->
    <div class="page-header px-6 md:px-8 py-7 fade-up">
      <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-1">Batch Management</p>
      <h1 id="batch-title" class="text-2xl md:text-3xl font-bold text-white">Loading Batch...</h1>
      <p id="batch-desc" class="text-white/60 text-sm mt-1">Please wait...</p>
    </div>

    <!-- Main Container -->
    <div class="p-6 md:p-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
        
        <!-- Left 2 Cols: Classes List -->
        <div class="lg:col-span-2 space-y-6">
          <div class="flex items-center justify-between border-b border-slate-100 pb-3">
            <h2 class="text-lg font-black text-gray-800 flex items-center gap-2">
              <svg class="w-5 h-5 text-garud-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              Scheduled & Live Classes
            </h2>
            <button onclick="window.location.href='/admin/live-classes'" class="text-xs font-bold text-garud-highlight hover:underline flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
              Back to Batches
            </button>
          </div>

          <div id="classes-list" class="space-y-4">
            <!-- Classes injected dynamically -->
            <div class="text-center py-10 bg-white border border-gray-100 rounded-2xl shadow-sm">
              <div class="animate-spin inline-block w-6 h-6 border-4 border-current border-t-transparent text-garud-accent rounded-full" role="status"></div>
              <p class="text-gray-400 text-xs mt-2">Loading scheduled classes...</p>
            </div>
          </div>
        </div>

        <!-- Right 1 Col: Student Enrollment -->
        <div class="bg-white border border-gray-100 shadow-sm rounded-3xl p-6 space-y-5">
          <div>
            <h3 class="font-extrabold text-gray-800 text-base">Student Enrollment</h3>
            <p class="text-gray-400 text-xs mt-0.5">Enroll students into this live class batch</p>
          </div>

          <!-- Search students -->
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </span>
            <input type="text" id="student-search" placeholder="Search by name or email..."
                   class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:border-garud-accent bg-gray-50 text-xs"/>
          </div>

          <!-- Select All / Deselect buttons -->
          <div class="flex justify-between items-center text-xs">
            <span class="text-gray-400 font-semibold">Toggle Selection:</span>
            <div class="flex gap-3">
              <button onclick="selectAllStudents(true)" class="text-garud-accent hover:underline font-bold">Select All</button>
              <button onclick="selectAllStudents(false)" class="text-gray-500 hover:underline font-semibold">Clear All</button>
            </div>
          </div>

          <!-- Scrollable Checkbox List -->
          <div id="students-enroll-container" class="max-h-[350px] overflow-y-auto space-y-2 pr-1">
            <div class="text-center py-6">
              <div class="animate-spin inline-block w-5 h-5 border-4 border-current border-t-transparent text-garud-accent rounded-full" role="status"></div>
              <p class="text-gray-400 text-2xs mt-2">Loading students directory...</p>
            </div>
          </div>

          <!-- Save Button -->
          <button id="save-enroll-btn" onclick="saveEnrollment()"
                  class="w-full py-3 bg-garud-highlight text-white font-extrabold rounded-2xl hover:opacity-95 transition text-sm shadow-md shadow-garud-highlight/15">
            Save Enrollment
          </button>
        </div>

      </div>
    </div>
  </div>

  <script src="/js/pages/admin/live-batch-detail.js"></script>
</body>
</html>
