<%- include('../partials/head', { title: 'Edit Course' }) %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap');

  .coursepw-shell {
    font-family: 'Outfit', sans-serif;
  }
  .coursepw-title {
    font-family: 'Sora', sans-serif;
    letter-spacing: -0.02em;
  }
  .coursepw-hero {
    border-radius: 1.5rem;
    background: linear-gradient(125deg, #0F172A 0%, #1E293B 58%, #334155 100%);
    box-shadow: 0 24px 50px rgba(15, 23, 42, 0.1);
    position: relative;
    overflow: hidden;
  }
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .top-progress-wrap {
    height: 4px;
    width: 100%;
    background-color: #F1F5F9;
    position: absolute;
    top: 0;
    left: 0;
  }
  .top-progress-fill {
    height: 100%;
    background-color: #22C55E;
  }
  .play-badge {
    position: absolute;
    bottom: -6px;
    right: -6px;
    background-color: #EF4444;
    border-radius: 999px;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #fff;
    color: #fff;
  }
</style>

<body class="min-h-screen bg-[#F8FAFC] text-slate-900 coursepw-shell">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen page-body">
    <div class="px-4 py-4 w-full">
      
      <!-- Compact Header & Stats -->
      <div class="bg-white border border-slate-200 shadow-sm rounded-xl p-3 mb-5 flex flex-wrap md:flex-nowrap items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <button onclick="window.location.href='/admin/courses/create/new'" class="w-8 h-8 rounded-lg bg-slate-100 hover:bg-slate-200 text-slate-600 flex items-center justify-center transition shrink-0" aria-label="Back">
            &larr;
          </button>
          <div>
            <div class="flex items-center gap-2">
              <p class="text-[9px] font-extrabold tracking-widest uppercase text-slate-400">Admin Editor</p>
            </div>
            <h1 id="page-title" class="text-lg font-bold text-slate-800 leading-tight">Edit Course</h1>
          </div>
        </div>

        <div class="flex items-center gap-4 bg-slate-50 px-4 py-2 rounded-lg border border-slate-100 text-xs">
          <div class="flex flex-col">
            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Lectures</span>
            <span id="meta-lectures" class="font-bold text-slate-800">0</span>
          </div>
          <div class="w-px h-6 bg-slate-200"></div>
          <div class="flex flex-col">
            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Purchases</span>
            <span id="meta-purchases" class="font-bold text-slate-800">0</span>
          </div>
          <div class="w-px h-6 bg-slate-200 hidden md:block"></div>
          <div class="flex flex-col hidden md:flex">
            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Created By</span>
            <span id="meta-created-by" class="font-semibold text-slate-800">-</span>
          </div>
          <div class="w-px h-6 bg-slate-200 hidden lg:block"></div>
          <div class="flex flex-col hidden lg:flex">
            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Updated</span>
            <span id="meta-updated-at" class="font-semibold text-slate-800">-</span>
          </div>
        </div>

        <div class="flex items-center gap-2 shrink-0">
          <button id="edit-details-btn" type="button" class="px-3 py-1.5 bg-white border border-slate-200 text-slate-700 rounded-lg text-xs font-bold hover:bg-slate-50 transition shadow-sm">
            <i class="fas fa-edit mr-1"></i> Edit Details
          </button>
          <button id="delete-course-btn" type="button" class="px-3 py-1.5 bg-white border border-red-200 text-red-500 rounded-lg text-xs font-bold hover:bg-red-50 transition shadow-sm">
            <i class="fas fa-trash-alt"></i>
          </button>
        </div>
      </div>

      <section id="loading-state" class="flex items-center justify-center min-h-[58vh]">
        <div class="spinner border-t-blue-600"></div>
      </section>

      <section id="error-state" class="hidden bg-white rounded-2xl shadow-sm border border-red-100 p-6 text-sm text-red-600 text-center"></section>

      <section id="editor-state" class="hidden space-y-6 fade-up-1">
        <form id="edit-course-form" class="space-y-6">
          <!-- Modal Backdrop for Basic Details -->
          <div id="details-modal" class="fixed inset-0 bg-slate-900/60 z-[150] flex items-center justify-center p-4 backdrop-blur-sm transition-opacity duration-300 hidden">
            <!-- Modal Card -->
            <div class="bg-white rounded-2xl shadow-xl border border-slate-100 w-full max-w-2xl overflow-hidden transform scale-95 transition-transform duration-300">
              <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50">
                <h3 class="text-base font-bold text-slate-800">Edit Course Metadata</h3>
                <button id="close-modal-btn" type="button" class="text-slate-400 hover:text-slate-600 font-bold text-lg">✕</button>
              </div>
              <div class="p-6 space-y-4 max-h-[70vh] overflow-y-auto">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-[10px] font-extrabold text-slate-500 uppercase tracking-wider mb-1">Course Name</label>
                    <input id="course-name" type="text" maxlength="80" required class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none" />
                  </div>
                  <div>
                    <label class="block text-[10px] font-extrabold text-slate-500 uppercase tracking-wider mb-1">Price (INR)</label>
                    <input id="course-price" type="number" min="0" step="1" class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none" />
                  </div>
                </div>

                <div>
                  <label class="block text-[10px] font-extrabold text-slate-500 uppercase tracking-wider mb-1">Description</label>
                  <textarea id="course-description" rows="3" maxlength="300" class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold resize-none focus:outline-none"></textarea>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <div>
                    <label class="block text-[10px] font-extrabold text-slate-500 uppercase tracking-wider mb-1">Category</label>
                    <select id="course-made-for" class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold bg-white focus:outline-none">
                      <option value="other">Other</option>
                      <option value="jee">JEE</option>
                      <option value="neet">NEET</option>
                    </select>
                  </div>
                  <div>
                    <label class="block text-[10px] font-extrabold text-slate-500 uppercase tracking-wider mb-1">Image URL</label>
                    <input id="course-image" type="url" placeholder="https://..." class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none" />
                  </div>
                  <div>
                    <label class="block text-[10px] font-extrabold text-slate-500 uppercase tracking-wider mb-1">Tags</label>
                    <input id="course-tags" type="text" placeholder="foundation, revision" class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none" />
                  </div>
                </div>

                <label class="inline-flex items-center gap-2 text-xs font-bold text-slate-600 cursor-pointer">
                  <input id="course-published" type="checkbox" class="rounded border-slate-300 text-blue-600 focus:ring-blue-600" />
                  Publish course publicly
                </label>
              </div>
              <div class="px-6 py-4 border-t border-slate-100 bg-slate-50 flex items-center justify-end gap-3">
                <button id="close-modal-cancel-btn" type="button" class="text-xs font-bold text-slate-500 hover:text-slate-700 mr-2">Cancel</button>
                <button id="save-course-btn" type="submit" class="px-5 py-2.5 rounded-xl bg-blue-600 text-white font-bold text-xs hover:bg-blue-700 transition shadow-sm">Save Course Details</button>
              </div>
            </div>
          </div>

          <!-- Tab Bar Area -->
          <div class="border-b border-slate-200 mb-6 mt-8">
            <div id="tab-container" class="flex items-center gap-6 overflow-x-auto hide-scrollbar pb-px">
              <button type="button" data-tab="content" class="px-1 py-3 text-sm font-semibold border-b-2 transition-colors whitespace-nowrap cursor-pointer border-blue-600 text-blue-600">Curriculum Content</button>
              <button type="button" data-tab="tests" class="px-1 py-3 text-sm font-semibold border-b-2 transition-colors whitespace-nowrap cursor-pointer border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300">Attached Tests</button>
            </div>
          </div>

          <!-- Curriculum Section -->
          <div id="section-curriculum" class="bg-white rounded-2xl border border-slate-200 p-5 md:p-6 shadow-sm">
            <!-- Navigation Header / Breadcrumbs -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-slate-100 pb-4 mb-4">
              <div class="flex items-center gap-3">
                <button id="curriculum-back-btn" type="button" class="hidden w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center hover:bg-slate-200 text-slate-600 transition">
                  <i class="fas fa-arrow-left text-xs"></i>
                </button>
                <div class="flex flex-col">
                  <h3 id="curriculum-view-title" class="text-lg font-bold text-slate-800">Course Syllabus</h3>
                  <div id="curriculum-breadcrumbs" class="text-[10px] font-extrabold text-slate-400 flex items-center gap-1.5 mt-0.5 uppercase tracking-wider">
                    <span>Syllabus</span>
                  </div>
                </div>
              </div>
              <div id="curriculum-action-container"></div>
            </div>

            <!-- Dynamic Active Screen Container -->
            <div id="curriculum-workspace"></div>
          </div>

          <!-- Tests Workspace -->
          <div id="section-tests" class="bg-white rounded-2xl border border-slate-200 p-5 md:p-6 shadow-sm mt-6 hidden">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-slate-100 pb-4 mb-4">
              <div class="flex flex-col">
                <h3 class="text-lg font-bold text-slate-800">Course Tests</h3>
                <p class="text-[10px] font-extrabold text-slate-400 uppercase tracking-wider mt-0.5">Attach tests directly to this course</p>
              </div>
              <button id="add-test-btn" type="button" class="px-4 py-2.5 rounded-xl bg-slate-800 text-white text-xs font-bold hover:bg-slate-900 transition shadow-sm">
                <i class="fas fa-plus mr-1"></i> Attach Test
              </button>
            </div>
            
            <div id="course-tests-list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 xl:gap-5">
              <!-- Tests will be injected here -->
            </div>

            <!-- Add Test Modal -->
            <div id="add-test-modal" class="fixed inset-0 bg-slate-900/60 z-[150] flex items-center justify-center p-4 backdrop-blur-sm transition-opacity duration-300 hidden">
              <div class="bg-white rounded-2xl shadow-xl border border-slate-100 w-full max-w-lg overflow-hidden transform scale-95 transition-transform duration-300">
                <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50">
                  <h3 class="text-base font-bold text-slate-800">Select Test to Attach</h3>
                  <button id="close-test-modal-btn" type="button" class="text-slate-400 hover:text-slate-600 font-bold text-lg">✕</button>
                </div>
                <div class="p-6">
                  <select id="available-tests-select" class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-sm font-semibold focus:outline-none">
                    <option value="">Loading tests...</option>
                  </select>
                </div>
                <div class="px-6 py-4 border-t border-slate-100 bg-slate-50 flex items-center justify-end gap-3">
                  <button id="confirm-add-test-btn" type="button" class="px-4 py-2.5 rounded-xl bg-blue-600 text-white font-bold text-xs hover:bg-blue-700 transition shadow-sm">Attach Test</button>
                </div>
              </div>
            </div>
          </div>

        </form>
      </section>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <!-- Including dayjs from CDN for date formatting if needed -->
  <script src="https://cdn.jsdelivr.net/npm/dayjs@1/dayjs.min.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/admin/course-edit.js"></script>
</body>
</html>
