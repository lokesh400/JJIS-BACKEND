<%- include('../partials/head', { title: 'Manage Team' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen page-body">
    <div class="page-header px-6 md:px-8 py-7 fade-up">
      <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-1">Admin Panel</p>
      <h1 class="text-2xl md:text-3xl font-bold text-white">Manage Team</h1>
      <p class="text-white/60 text-sm mt-1">All users with role Teacher and Admin</p>
    </div>

    <div class="p-6 md:p-8">
      <div class="flex items-center justify-between mb-4">
        <p id="team-count" class="text-sm text-gray-500"></p>
        <div class="flex items-center gap-2">
          <button onclick="openAddMemberModal()" class="px-4 py-2 rounded-xl text-sm text-white bg-blue-600 hover:bg-blue-700 transition">Add New Member</button>
          <button onclick="loadTeamUsers()" class="px-4 py-2 border border-gray-200 rounded-xl text-sm text-gray-600 hover:bg-gray-50 transition">Refresh</button>
        </div>
      </div>

      <div id="team-loading" class="text-center py-16 text-gray-400 text-sm">Loading users...</div>
      <div id="team-empty" class="hidden text-center py-16 text-gray-500 text-sm">No Teacher or Admin users found.</div>

      <div class="overflow-x-auto bg-white rounded-2xl border border-gray-100 shadow-sm">
        <table class="min-w-full text-sm">
          <thead class="bg-gray-50 text-gray-600">
            <tr>
              <th class="px-4 py-3 text-left font-semibold">Name</th>
              <th class="px-4 py-3 text-left font-semibold">Email</th>
              <th class="px-4 py-3 text-left font-semibold">Role</th>
              <th class="px-4 py-3 text-left font-semibold">Mobile</th>
            </tr>
          </thead>
          <tbody id="team-tbody" class="divide-y divide-gray-100"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="add-member-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">
    <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-lg">
      <h3 class="font-bold text-gray-800 mb-4">Add New Member</h3>
      <form id="add-member-form" class="space-y-4">
        <div>
          <label class="block text-sm text-gray-600 mb-1">Name</label>
          <input id="member-name" type="text" required class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
        </div>
        <div>
          <label class="block text-sm text-gray-600 mb-1">Contact Mail</label>
          <input id="member-contact-mail" type="email" required class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
        </div>
        <div>
          <label class="block text-sm text-gray-600 mb-1">Subjects</label>
          <select id="member-subjects" multiple class="w-full px-3 py-2 border border-gray-300 rounded-lg min-h-36"></select>
          <p class="text-xs text-gray-400 mt-1">Hold Ctrl/Cmd to select multiple subjects.</p>
        </div>
        <div class="flex gap-2 pt-1">
          <button type="submit" class="px-4 py-2 rounded-xl text-sm text-white bg-blue-600 hover:bg-blue-700 transition">Submit</button>
          <button type="button" onclick="closeAddMemberModal()" class="px-4 py-2 border border-gray-200 rounded-xl text-sm text-gray-600 hover:bg-gray-50 transition">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/admin/manage-team.js"></script>
</body>
</html>
