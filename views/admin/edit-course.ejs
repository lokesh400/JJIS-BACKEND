<%- include('../partials/head', { title: 'Edit Course' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen page-body">
    <div class="page-header px-6 md:px-8 py-7 fade-up">
      <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-1">Admin Panel</p>
      <h1 id="page-title" class="text-2xl md:text-3xl font-bold text-white">Edit Course</h1>
      <p class="text-white/60 text-sm mt-1">Manage complete course data from one dedicated page.</p>
    </div>

    <div class="p-6 md:p-8 space-y-6">
      <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 md:p-5 lift fade-up-1">
        <div class="flex flex-wrap items-center justify-between gap-2">
          <div class="flex items-center gap-2">
            <a href="/admin/courses/create/new" class="px-3 py-2 rounded-lg border border-gray-300 text-sm text-gray-700 hover:bg-gray-50">Back to Courses</a>
            <button id="edit-details-btn" type="button" class="px-3 py-2 rounded-lg border border-slate-300 bg-slate-50 text-sm text-slate-700 hover:bg-slate-100 font-semibold transition">Edit Basic Details</button>
          </div>
          <button id="delete-course-btn" type="button" class="px-3 py-2 rounded-lg border border-red-200 text-sm text-red-600 hover:bg-red-50">Delete Course</button>
        </div>
      </section>

      <section id="loading-state" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 text-sm text-gray-500">Loading course...</section>

      <section id="error-state" class="hidden bg-white rounded-2xl shadow-sm border border-red-100 p-6 text-sm text-red-600"></section>

      <section id="editor-state" class="hidden space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
            <p class="text-xs uppercase tracking-wide text-gray-500">Lectures</p>
            <p id="meta-lectures" class="text-2xl font-bold text-gray-900 mt-1">0</p>
          </div>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
            <p class="text-xs uppercase tracking-wide text-gray-500">Purchases</p>
            <p id="meta-purchases" class="text-2xl font-bold text-gray-900 mt-1">0</p>
          </div>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
            <p class="text-xs uppercase tracking-wide text-gray-500">Created By</p>
            <p id="meta-created-by" class="text-sm font-semibold text-gray-900 mt-2">-</p>
          </div>
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
            <p class="text-xs uppercase tracking-wide text-gray-500">Updated</p>
            <p id="meta-updated-at" class="text-sm font-semibold text-gray-900 mt-2">-</p>
          </div>
        </div>

        <form id="edit-course-form" class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 md:p-6 space-y-5">
          <!-- Modal Backdrop for Basic Details -->
          <div id="details-modal" class="fixed inset-0 bg-slate-900/60 z-[150] flex items-center justify-center p-4 backdrop-blur-sm transition-opacity duration-300 hidden">
            <!-- Modal Card -->
            <div class="bg-white rounded-2xl shadow-xl border border-slate-100 w-full max-w-2xl overflow-hidden transform scale-95 transition-transform duration-300">
              <!-- Modal Header -->
              <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50">
                <h3 class="text-base font-bold text-slate-800">Edit Course Metadata</h3>
                <button id="close-modal-btn" type="button" class="text-slate-400 hover:text-slate-600 font-bold text-lg">✕</button>
              </div>
              <!-- Modal Body -->
              <div class="p-6 space-y-4 max-h-[70vh] overflow-y-auto">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label for="course-name" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Course Name</label>
                    <input id="course-name" type="text" maxlength="80" required class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none" />
                  </div>
                  <div>
                    <label for="course-price" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Price (INR)</label>
                    <input id="course-price" type="number" min="0" step="1" class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none" />
                  </div>
                </div>

                <div>
                  <label for="course-description" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Description</label>
                  <textarea id="course-description" rows="3" maxlength="300" class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold resize-none focus:outline-none"></textarea>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <div>
                    <label for="course-made-for" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Category</label>
                    <select id="course-made-for" class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold bg-white focus:outline-none">
                      <option value="other">Other</option>
                      <option value="jee">JEE</option>
                      <option value="neet">NEET</option>
                    </select>
                  </div>
                  <div>
                    <label for="course-image" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Image URL</label>
                    <input id="course-image" type="url" placeholder="https://..." class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none" />
                  </div>
                  <div>
                    <label for="course-tags" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Tags</label>
                    <input id="course-tags" type="text" placeholder="foundation, revision" class="w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none" />
                  </div>
                </div>

                <label class="inline-flex items-center gap-2 text-xs font-bold text-slate-600 cursor-pointer">
                  <input id="course-published" type="checkbox" class="rounded border-slate-300 text-garud-accent focus:ring-garud-accent" />
                  Publish course publicly
                </label>
              </div>
              <!-- Modal Footer -->
              <div class="px-6 py-4 border-t border-slate-100 bg-slate-50 flex items-center justify-end gap-3">
                <button id="save-modal-btn" type="button" class="px-4 py-2.5 rounded-xl bg-slate-700 text-white font-bold text-xs hover:bg-slate-800 transition shadow-sm">Done</button>
              </div>
            </div>
          </div>

          <div class="border border-slate-200 rounded-2xl p-4 md:p-6 bg-slate-50 space-y-4">
            <!-- Navigation Header / Breadcrumbs -->
            <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-200 pb-3">
              <div class="flex items-center gap-3">
                <button id="curriculum-back-btn" type="button" class="hidden px-3 py-1.5 rounded-xl bg-white border border-slate-200 hover:bg-slate-100 text-slate-700 text-xs font-bold transition shadow-sm">
                  <i class="fas fa-arrow-left mr-1"></i> Back
                </button>
                <div class="flex flex-col">
                  <h3 id="curriculum-view-title" class="text-base font-bold text-slate-800">Course Syllabus</h3>
                  <div id="curriculum-breadcrumbs" class="text-2xs font-semibold text-slate-500 flex items-center gap-1 mt-0.5 uppercase tracking-wider">
                    <span>Syllabus</span>
                  </div>
                </div>
              </div>
              <!-- Action Button will be populated dynamically -->
              <div id="curriculum-action-container"></div>
            </div>

            <!-- Dynamic Active Screen Container -->
            <div id="curriculum-workspace" class="space-y-4"></div>
          </div>

          <div class="pt-1 flex items-center justify-end gap-3">
            <a href="/admin/courses/create/new" class="px-4 py-2.5 rounded-xl border border-gray-300 text-gray-700 font-medium hover:bg-gray-50">Cancel</a>
            <button id="save-course-btn" type="submit" class="px-4 py-2.5 rounded-xl bg-garud-highlight text-white font-semibold hover:opacity-95">Update Course</button>
          </div>
        </form>
      </section>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/admin/course-edit.js"></script>
</body>
</html>
