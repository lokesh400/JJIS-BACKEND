<%- include('../partials/head', { title: 'Course Detail' }) %>
<body class="min-h-screen bg-[#F8FAFC] text-slate-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap');

    .coursepw-shell {
      font-family: 'Outfit', sans-serif;
    }

    .coursepw-title {
      font-family: 'Sora', sans-serif;
      letter-spacing: -0.02em;
    }

    .coursepw-hero {
      border-radius: 1.5rem;
      background: linear-gradient(125deg, #0F172A 0%, #1E293B 58%, #334155 100%);
      box-shadow: 0 24px 50px rgba(15, 23, 42, 0.1);
      position: relative;
      overflow: hidden;
    }

    /* Custom Scrollbar for Tab bar */
    .hide-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .hide-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    /* Top Progress Bar for Lecture Card */
    .top-progress-wrap {
      height: 4px;
      width: 100%;
      background-color: #F1F5F9;
      position: absolute;
      top: 0;
      left: 0;
    }
    .top-progress-fill {
      height: 100%;
      background-color: #22C55E;
    }

    .play-badge {
      position: absolute;
      bottom: -6px;
      right: -6px;
      background-color: #EF4444;
      border-radius: 999px;
      width: 22px;
      height: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid #fff;
      color: #fff;
    }
  </style>

  <div class="md:ml-60 pt-14 min-h-screen page-body coursepw-shell">
    <div class="px-4 py-6 md:px-8 md:py-8 max-w-7xl mx-auto">
      
      <!-- Hero Section -->
      <div class="coursepw-hero p-5 md:p-7 fade-up">
        <div class="relative z-10">
          <div class="flex items-start gap-3 md:gap-4">
            <button onclick="window.location.href='/student/purchase-courses'"
                    class="w-10 h-10 md:w-11 md:h-11 flex items-center justify-center rounded-xl bg-white/15 hover:bg-white/25 text-white transition shrink-0"
                    aria-label="Back">
              &larr;
            </button>
            <div class="flex-1 min-w-0">
              <p class="text-[11px] md:text-xs font-semibold tracking-[0.2em] uppercase text-slate-200/80">Study Room</p>
              <h1 id="course-name" class="coursepw-title text-2xl md:text-3xl lg:text-4xl text-white mt-1"></h1>
              <p id="course-desc" class="text-sm text-slate-200/90 mt-2 hidden max-w-3xl"></p>
              
              <!-- Breadcrumbs injected here dynamically via JS -->
              <div id="breadcrumb-container" class="mt-4 hidden flex items-center gap-2 text-sm text-slate-300 font-semibold"></div>
            </div>
          </div>
          <div id="purchase-actions" class="mt-5"></div>
        </div>
      </div>

      <div id="loading" class="flex items-center justify-center min-h-[58vh]"><div class="spinner border-t-blue-600"></div></div>

      <div id="main-content" class="hidden mt-6 md:mt-7 fade-up-1">
        
        <!-- Tab Bar Area -->
        <div class="border-b border-slate-200 mb-6">
          <div id="tab-container" class="flex items-center gap-6 overflow-x-auto hide-scrollbar pb-px">
            <!-- Tabs injected dynamically -->
          </div>
        </div>

        <!-- Dynamic Content Area -->
        <div id="dynamic-grid" class="w-full">
            <!-- Grid for Subjects or Chapters or Lectures injected here -->
        </div>

      </div>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <!-- Including dayjs from CDN for date formatting -->
  <script src="https://cdn.jsdelivr.net/npm/dayjs@1/dayjs.min.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/student/course-view.js"></script>
</body>
</html>
