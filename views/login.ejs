<%- include('./partials/head', { title: 'Sign In' }) %>
<body class="min-h-screen flex items-center justify-center bg-gradient-to-br from-garud-dark via-garud-mid to-garud-accent relative overflow-hidden">

  <!-- Decorative blobs -->
  <div class="absolute top-[-80px] left-[-80px] w-72 h-72 bg-garud-highlight/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-[-60px] right-[-60px] w-64 h-64 bg-garud-accent/20 rounded-full blur-3xl"></div>

  <div class="max-w-md w-full mx-4 relative z-10 fade-up">
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-tr from-garud-highlight to-rose-500 border border-white/10 shadow-lg shadow-garud-highlight/20 mb-4 animate-bounce">
        <span class="text-2xl font-black text-white">G</span>
      </div>
      <h1 class="text-3xl font-black text-white tracking-tight">GARUD <span class="text-garud-highlight">Classes</span></h1>
      <p class="text-white/50 text-xs font-semibold uppercase tracking-wider mt-1.5">Test Portal — Sign in to continue</p>
    </div>

    <!-- Glassmorphic Card -->
    <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-3xl shadow-2xl p-8 relative overflow-hidden">
      <!-- Top highlight border effect -->
      <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-garud-highlight/50 to-transparent"></div>

      <h2 class="text-xl font-bold text-white mb-6 tracking-tight">Welcome back</h2>

      <form id="login-form" class="space-y-4" novalidate>
        <!-- Email Input -->
        <div>
          <label class="block text-[10px] font-bold text-white/50 uppercase tracking-widest mb-1.5">Email Address</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-white/40">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </span>
            <input id="email" type="email" autocomplete="email"
                   class="w-full pl-11 pr-4 py-3 bg-white/10 border border-white/10 text-white placeholder-white/30 rounded-xl focus:ring-2 focus:ring-garud-highlight focus:border-garud-highlight outline-none transition-all duration-200"
                   placeholder="Enter your email" required/>
          </div>
        </div>

        <!-- Password Input -->
        <div>
          <label class="block text-[10px] font-bold text-white/50 uppercase tracking-widest mb-1.5">Password</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-white/40">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </span>
            <input id="password" type="password" autocomplete="current-password"
                   class="w-full pl-11 pr-12 py-3 bg-white/10 border border-white/10 text-white placeholder-white/30 rounded-xl focus:ring-2 focus:ring-garud-highlight focus:border-garud-highlight outline-none transition-all duration-200"
                   placeholder="Enter your password" required/>
            <button id="toggle-password" type="button" class="absolute inset-y-0 right-0 flex items-center pr-3.5 text-white/40 hover:text-white/80 transition-colors duration-150">
              <!-- Eye open icon (default) -->
              <svg id="eye-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              <!-- Eye closed icon (hidden by default) -->
              <svg id="eye-closed" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
              </svg>
            </button>
          </div>
        </div>

        <div class="flex items-center justify-end text-xs pt-1">
          <button id="forgot-open-btn" type="button" class="text-garud-highlight font-bold hover:underline transition">Forgot Password?</button>
        </div>

        <!-- Submit Button -->
        <button id="submit-btn" type="submit"
                class="w-full py-3.5 bg-gradient-to-r from-garud-highlight to-rose-600 hover:from-rose-500 hover:to-garud-highlight text-white font-extrabold rounded-xl
                       shadow-lg shadow-garud-highlight/15 active:scale-[0.98] transition-all duration-200 disabled:opacity-50 mt-4">
          Sign In
        </button>
      </form>

      <p class="mt-6 text-center text-xs text-white/50 font-medium">
        Don't have an account?
        <a href="/register" class="text-garud-highlight font-bold hover:underline transition">Register here</a>
      </p>

      <div class="mt-6 pt-5 border-t border-white/5 flex flex-col sm:flex-row items-center justify-center gap-3 text-xs text-white/40">
        <a href="tel:9896913009" class="flex items-center gap-1.5 hover:text-white/70 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-garud-highlight" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          9896913009
        </a>
        <span class="hidden sm:block text-white/10">&bull;</span>
        <a href="mailto:info@garudclasses.com" class="flex items-center gap-1.5 hover:text-white/70 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-garud-highlight" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          info@garudclasses.com
        </a>
      </div>
    </div>
  </div>

  <%- include('./partials/toast') %>
  <div id="forgot-modal" class="hidden fixed inset-0 z-50">
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 min-h-screen flex items-center justify-center p-4">
      <div class="w-full max-w-md rounded-2xl bg-slate-900 border border-white/10 p-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-white font-bold">Reset Password</h3>
          <button id="forgot-close-btn" type="button" class="text-white/60 hover:text-white text-xl leading-none">&times;</button>
        </div>
        <div id="fp-step1" class="space-y-3">
          <input id="fp-identifier" type="text" placeholder="Email or username" class="w-full px-3 py-2 bg-white/10 border border-white/15 text-white rounded-lg outline-none"/>
          <button id="fp-send-otp-btn" type="button" class="w-full py-2.5 bg-garud-highlight text-white rounded-lg font-semibold">Send Reset Link</button>
        </div>
        <div id="fp-step2" class="hidden space-y-3 text-sm text-white/70">Reset link sent. Please check your email.</div>
        <div id="fp-step3" class="hidden space-y-3">
          <input id="fp-new-password" type="password" placeholder="New password (min 8 chars)" class="w-full px-3 py-2 bg-white/10 border border-white/15 text-white rounded-lg outline-none"/>
          <button id="fp-set-password-btn" type="button" class="w-full py-2.5 bg-garud-highlight text-white rounded-lg font-semibold">Set New Password</button>
        </div>
      </div>
    </div>
  </div>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/pages/public/login.js"></script>
</body>
</html>
