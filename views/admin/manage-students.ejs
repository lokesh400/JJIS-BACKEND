<%- include('../partials/head', { title: 'Manage Students' }) %>
<body class="min-h-screen bg-slate-50 text-gray-900">
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <div class="md:ml-60 pt-14 min-h-screen page-body">
    <div class="page-header px-6 md:px-8 py-7 fade-up">
      <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-1">Admin Panel</p>
      <h1 class="text-2xl md:text-3xl font-bold text-white">Student Purchase Directory</h1>
      <p class="text-white/60 text-sm mt-1">Search student registrations and track purchased courses and test series.</p>
    </div>

    <div class="p-6 md:p-8">
      <!-- Search & Filters -->
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-6">
        <div class="relative w-full sm:max-w-md">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </span>
          <input id="student-search" type="text" placeholder="Search by name, email, or mobile..." 
                 class="w-full pl-10 pr-4 py-2.5 bg-white border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/25 focus:border-blue-500 transition shadow-sm" />
        </div>
        <div class="flex items-center gap-2 w-full sm:w-auto">
          <p id="student-count" class="text-sm text-gray-500 font-medium"></p>
          <button onclick="loadStudents()" class="ml-auto sm:ml-0 px-4 py-2.5 border border-gray-200 rounded-xl text-sm font-medium text-gray-600 bg-white hover:bg-gray-50 transition shadow-sm">Refresh</button>
        </div>
      </div>

      <!-- Loading and Empty States -->
      <div id="students-loading" class="text-center py-16 text-gray-400 text-sm">Loading students...</div>
      <div id="students-empty" class="hidden text-center py-16 text-gray-500 text-sm">No students found.</div>

      <!-- Students Table -->
      <div class="overflow-x-auto bg-white rounded-2xl border border-gray-100 shadow-sm">
        <table class="min-w-full text-sm">
          <thead class="bg-gray-50 text-gray-600">
            <tr>
              <th class="px-6 py-4 text-left font-semibold">Student Name</th>
              <th class="px-6 py-4 text-left font-semibold">Contact Identifiers</th>
              <th class="px-6 py-4 text-left font-semibold">Mobile Number</th>
              <th class="px-6 py-4 text-left font-semibold">Registered Date</th>
              <th class="px-6 py-4 text-right font-semibold">Actions</th>
            </tr>
          </thead>
          <tbody id="students-tbody" class="divide-y divide-gray-100"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Purchases Detail Modal -->
  <div id="purchases-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4 backdrop-blur-sm transition-opacity duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl overflow-hidden transform transition-all scale-95 duration-300">
      <!-- Modal Header -->
      <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-4 flex items-center justify-between">
        <div>
          <h3 class="font-bold text-white text-lg">Purchase History</h3>
          <p id="modal-student-name" class="text-white/80 text-xs mt-0.5"></p>
        </div>
        <button onclick="closePurchasesModal()" class="text-white/80 hover:text-white hover:bg-white/10 p-1.5 rounded-lg transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <!-- Modal Body -->
      <div class="p-6 max-h-[500px] overflow-y-auto bg-slate-50/50">
        <div id="purchases-loading" class="text-center py-10 text-gray-400 text-sm">Loading purchases...</div>
        <div id="purchases-empty" class="hidden text-center py-10 text-gray-500 text-sm">This student has not purchased any courses or test series yet.</div>
        
        <div id="purchases-container" class="space-y-4"></div>
      </div>

      <!-- Modal Footer -->
      <div class="px-6 py-4 border-t border-gray-100 flex justify-end bg-white">
        <button onclick="closePurchasesModal()" class="px-4 py-2 border border-gray-200 rounded-xl text-sm font-semibold text-gray-600 hover:bg-gray-50 transition">Close</button>
      </div>
    </div>
  </div>

  <!-- Manual Enrollment Modal -->
  <div id="enroll-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4 backdrop-blur-sm transition-opacity duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden transform transition-all scale-95 duration-300">
      <!-- Modal Header -->
      <div class="bg-gradient-to-r from-violet-600 to-indigo-600 px-6 py-4 flex items-center justify-between">
        <div>
          <h3 class="font-bold text-white text-lg">Manual Student Enrollment</h3>
          <p id="modal-enroll-student-name" class="text-white/80 text-xs mt-0.5"></p>
        </div>
        <button onclick="closeEnrollModal()" class="text-white/80 hover:text-white hover:bg-white/10 p-1.5 rounded-lg transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <!-- Modal Body -->
      <form id="enroll-form" class="p-6 space-y-4 bg-slate-50/50">
        <div>
          <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1.5">Enrollment Type</label>
          <select id="enroll-item-type" required
                  class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/25 focus:border-violet-500 transition shadow-sm">
            <option value="">Select Type</option>
            <option value="Course">Premium Course / Batch</option>
            <option value="TestSeries">Test Series</option>
          </select>
        </div>

        <div>
          <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1.5">Select Course / Test Series</label>
          <select id="enroll-item-select" required disabled
                  class="w-full px-3.5 py-2.5 bg-white border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/25 focus:border-violet-500 transition shadow-sm disabled:bg-gray-100 disabled:text-gray-400">
            <option value="">Select Type First</option>
          </select>
        </div>

        <div class="bg-violet-50/50 border border-violet-100/80 rounded-xl p-4 space-y-2 mt-2">
          <div class="flex justify-between items-center text-xs font-semibold text-violet-700 uppercase tracking-wider">
            <span>Price Model</span>
            <span class="bg-violet-100 text-violet-800 px-2 py-0.5 rounded-full font-bold">Free Receipt</span>
          </div>
          <div class="flex justify-between items-center text-slate-700 text-sm">
            <span>Amount Paid</span>
            <span class="font-extrabold text-slate-800">₹0</span>
          </div>
          <div class="flex justify-between items-center text-slate-700 text-sm">
            <span>Payment Method</span>
            <span class="font-semibold text-slate-800">Free / Manual</span>
          </div>
          <div class="flex justify-between items-center text-slate-700 text-sm">
            <span>Status</span>
            <span class="font-bold text-emerald-600">Success</span>
          </div>
        </div>

        <!-- Modal Footer -->
        <div class="flex justify-end gap-2 pt-3 border-t border-gray-100">
          <button type="button" onclick="closeEnrollModal()" 
                  class="px-4 py-2 border border-gray-200 rounded-xl text-sm font-semibold text-gray-600 hover:bg-gray-50 transition">Cancel</button>
          <button type="submit" 
                  class="px-4 py-2 bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-700 hover:to-indigo-700 text-white rounded-xl text-sm font-bold shadow-md hover:shadow-lg transition">Confirm Enrollment</button>
        </div>
      </form>
    </div>
  </div>

  <%- include('../partials/toast') %>
  <script src="/js/api.js"></script>
  <script src="/js/toast.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/pages/admin/manage-students.js"></script>
</body>
</html>
